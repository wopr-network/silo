{
  "name": "@wopr-network/holyship",
  "version": "0.2.2",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=24.0.0"
  },
  "main": "./dist/src/main.js",
  "bin": {
    "holyship": "./dist/src/execution/cli.js"
  },
  "types": "./dist/src/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/main.d.ts",
      "import": "./dist/src/main.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "drizzle",
    "gates"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc",
    "prepublishOnly": "pnpm build",
    "dev": "tsx src/main.ts",
    "lint": "biome check src/",
    "lint:fix": "biome check --fix src/",
    "format": "biome format --write src/",
    "check": "biome check src/ && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.71",
    "@anthropic-ai/sdk": "^0.78.0",
    "@hono/node-server": "^1.19.11",
    "@linear/sdk": "^76.0.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@sentry/node": "^10.43.0",
    "@trpc/server": "^11.12.1",
    "@wopr-network/platform-core": "^1.34.0",
    "better-auth": "^1.5.5",
    "commander": "^14.0.3",
    "dockerode": "^4.0.9",
    "drizzle-orm": "^0.45.1",
    "handlebars": "^4.7.8",
    "hono": "^4.12.5",
    "mcp-remote": "^0.1.18",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.8",
    "resend": "^6.9.3",
    "stripe": "^20.4.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@electric-sql/pglite": "^0.3.16",
    "@types/node": "^25.3.3",
    "@types/pg": "^8.15.6",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.0.18",
    "drizzle-kit": "^0.31.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "pnpm": {},
  "publishConfig": {
    "access": "public"
  },
  "release": {
    "extends": "@wopr-network/semantic-release-config"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wopr-network/holyship.git"
  }
}
